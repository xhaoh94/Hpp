{
  "name": "hpp",
  "version": "0.0.4",
  "description": "Lightweight terminal project manager",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "electron-vite build && node scripts/package-agent-plugins.cjs",
    "dist": "npm run build && electron-builder",
    "dist:publish": "npm run build && electron-builder --publish always",
    "preview": "electron-vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "adm-zip": "^0.5.18",
    "electron-updater": "^6.8.9",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.hpp.app",
    "productName": "hpp",
    "forceCodeSigning": false,
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "xhaoh94",
        "repo": "Hpp",
        "releaseType": "release"
      }
    ],
    "files": [
      "out/**/*"
    ],
    "asar": false,
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "mac": {
      "icon": "public/icon.png"
    },
    "linux": {
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "esbuild@0.25.12": true
  }
}
