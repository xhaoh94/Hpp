{
  "name": "hpp",
  "version": "1.0.0",
  "description": "Lightweight terminal project manager",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^33.4.11",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^6.4.3"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.hpp.app",
    "productName": "hpp",
    "forceCodeSigning": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "mac": {
      "icon": "public/icon.png"
    },
    "linux": {
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
